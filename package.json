{
  "name": "pichanga-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "Pichanga Dual - Web Dashboard para Dueños de Canchas",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:debug": "NODE_OPTIONS='--inspect' next dev --turbopack",
    "build": "next build --turbopack",
    "build:analyze": "ANALYZE=true next build --turbopack",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "format": "prettier --write \"**/*.{js,ts,tsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{js,ts,tsx,json,md,css}\"",
    "clean": "rm -rf .next node_modules",
    "clean:cache": "rm -rf .next",
    "reset": "rm -rf .next node_modules bun.lockb && bun install"
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.3",
    "@tanstack/react-query": "^5.68.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.483.0",
    "next": "^15.2.4",
    "next-themes": "^0.4.6",
    "ogl": "^1.0.11",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-day-picker": "^9.6.3",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.1",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.0.2",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.11",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.12",
    "typescript": "^5.8.2",
    "tailwindcss": "^4.0.14",
    "@tailwindcss/postcss": "^4.0.14",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.4",
    "@eslint/eslintrc": "^3.3.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
